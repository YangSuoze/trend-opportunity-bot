# LLM (OpenAI-compatible)
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=qwen3-max

# GitHub token (optional but recommended to avoid strict rate limits)
GITHUB_TOKEN=

# Product Hunt token (optional)
PRODUCTHUNT_TOKEN=

# Reddit OAuth (optional). Required to enable Reddit collector.
# Create an app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=python:trend-opportunity-bot:v0.1.0 (by /u/yourname)
# Comma-separated subreddits (e.g. SideProject,startups,selfhosted)
REDDIT_SUBREDDITS=

# DEV.to tags (optional) comma-separated (e.g. buildinpublic,saas,startup)
DEVTO_TAGS=

# Substack RSS feeds (optional) comma-separated feed URLs
# e.g. https://example.substack.com/feed
SUBSTACK_FEEDS=
